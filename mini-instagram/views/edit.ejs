<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Instagram | Edit Post</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen pb-10">
    <nav class="bg-white shadow-sm p-4 flex justify-between items-center px-10 mb-8">
        <h1 class="text-xl font-bold text-gray-800">Edit Post</h1>
        <div class="space-x-4">
            <a href="/profile" class="text-blue-500 font-semibold hover:text-blue-600">Back to Profile</a>
        </div>
    </nav>

    <div class="max-w-2xl mx-auto px-4">
        <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
            <img src="/images/uploads/<%= post.image %>" class="w-full h-80 object-cover bg-gray-50">
            <div class="p-6">
                <form action="/post/edit/<%= post._id %>" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Caption</label>
                        <textarea name="content" class="w-full p-3 border rounded-lg focus:ring-blue-500 focus:border-blue-500" rows="4"><%= post.content %></textarea>
                    </div>
                    <div class="flex items-center space-x-4">
                        <button type="submit" class="bg-blue-500 text-white px-6 py-2 rounded-lg font-bold hover:bg-blue-600">Save Changes</button>
                        <a href="/profile" class="text-gray-500 font-semibold hover:underline">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
