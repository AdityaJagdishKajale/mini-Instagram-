<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Instagram | Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen pb-10">
    <nav class="bg-white shadow-sm p-4 flex justify-between items-center px-10">
        <h1 class="text-xl font-bold text-gray-800">Mini Instagram</h1>
        <div class="space-x-4">
            <a href="/feed" class="text-blue-500 font-semibold hover:text-blue-600">Feed</a>
            <a href="/auth/logout" class="text-red-500 font-semibold hover:text-red-600">Logout</a>
        </div>
    </nav>

    <div class="max-w-3xl mx-auto mt-8 px-4">
        <div class="bg-white p-6 rounded-lg shadow-sm mb-8 border border-gray-100">
            <h2 class="text-2xl font-bold mb-2">Hello, <%= user.username %>!</h2>
            <p class="text-gray-600 mb-6">Welcome to your profile.</p>

            <h3 class="text-lg font-bold mb-4">Create New Post</h3>
            <form action="/post/upload" method="POST" enctype="multipart/form-data" class="space-y-4">
                <div>
                    <input type="file" name="image" required class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
                </div>
                <div>
                    <textarea name="content" placeholder="Write a caption..." class="w-full p-3 border rounded-lg focus:ring-blue-500 focus:border-blue-500" rows="3"></textarea>
                </div>
                <button type="submit" class="bg-blue-500 text-white px-6 py-2 rounded-lg font-bold hover:bg-blue-600">Post</button>
            </form>
        </div>

        <h3 class="text-xl font-bold mb-4">Your Posts</h3>
        <% if (user.posts && user.posts.length > 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% user.posts.slice().reverse().forEach(function(post) { %>
                    <div class="bg-white rounded-lg shadow-sm overflow-hidden border border-gray-100">
                        <img src="/images/uploads/<%= post.image %>" class="w-full h-64 object-cover bg-gray-100">
                        <div class="p-4">
                            <p class="text-gray-800 mb-4 whitespace-pre-wrap"><%= post.content %></p>
                            <div class="flex justify-end space-x-3 text-sm font-semibold border-t pt-3 mt-2">
                                <a href="/post/edit/<%= post._id %>" class="text-blue-500 hover:underline">Edit</a>
                                <form action="/post/delete/<%= post._id %>" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this post?');">
                                    <button type="submit" class="text-red-500 hover:underline">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="bg-white p-6 rounded-lg shadow-sm text-center text-gray-500 italic">
                You haven't posted anything yet. Share something with the world!
            </div>
        <% } %>
    </div>
</body>
</html>
